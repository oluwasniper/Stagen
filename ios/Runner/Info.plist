	<string>This app needs access to your contacts to import contact details for QR code generation.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>This app uses your location to discover and suggest nearby Wi‑Fi networks (SSIDs) for you to connect to.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>QR code scanner needs photos access to get QR code from photo library</string>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
