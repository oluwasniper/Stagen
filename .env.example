# ─────────────────────────────────────────────────────────────────────────────
# Scagen — Required build-time configuration
# ─────────────────────────────────────────────────────────────────────────────
#
# This project uses --dart-define flags to inject public build-time configuration
# values into the binary (not secure secrets). Values are compiled into the
# binary and NOT bundled as readable assets.
#
# SETUP:
#   1. Copy this file:  cp .env.example .env   (.env is gitignored)
#   2. Fill in all values below
#   3. Build with the Makefile:  make run  |  make build-android  |  make build-ios
#      (Makefile passes --dart-define-from-file=.env automatically)
#      OR run manually:
#        flutter run --dart-define-from-file=.env
# ─────────────────────────────────────────────────────────────────────────────

# ── Appwrite ──────────────────────────────────────────────────────────────────
# API endpoint (e.g. https://fra.cloud.appwrite.io/v1 for Frankfurt cloud).
# APPWRITE_URL is also accepted as a backward-compatible alias.
APPWRITE_ENDPOINT=

# Project ID — found in Appwrite Console → Project Settings
APPWRITE_PROJECT_ID=

# Project name — optional, used for display/metadata
APPWRITE_PROJECT_NAME=scagen

# ── PostHog ───────────────────────────────────────────────────────────────────
# Project API key — found in PostHog → Project Settings → API Keys (starts with phc_)
POSTHOG_API_KEY=

# PostHog host — US cloud (default), EU cloud, or self-hosted
# US cloud:  https://us.i.posthog.com
# EU cloud:  https://eu.i.posthog.com
POSTHOG_HOST=https://us.i.posthog.com
