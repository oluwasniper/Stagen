# FVM Version Cache
.fvm/

# ── Secrets & local overrides ────────────────────────────────────────────────
# Real credentials live in .env (gitignored). Use .env.example as the template.
.env
.env.local
.env.*.local
.codemagic.env
*.env
!.env.example
/android/key.properties
/android/*.jks
/android/*.keystore
/android/app/google-services.json
/ios/Runner/GoogleService-Info.plist
/ios/build/

# VS Code launch.json contains --dart-define values with real secrets.
# Use .vscode/launch.json.example as the committed template instead.
.vscode/launch.json

# Cloudflare Wrangler local state
.wrangler/

