{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Scagen (debug)",
      "request": "launch",
      "type": "dart",
      "toolArgs": [
        "--dart-define-from-file=.env"
      ]
    },
    {
      "name": "Scagen (profile)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "profile",
      "toolArgs": [
        "--dart-define-from-file=.env"
      ]
    },
    {
      "name": "Scagen (release)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "release",
      "toolArgs": [
        "--dart-define-from-file=.env"
      ]
    }
  ]
}
